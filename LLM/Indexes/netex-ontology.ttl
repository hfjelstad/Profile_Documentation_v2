## =================================================================
## RELATIONSHIPS (@ref properties) — SUPERSET
## =================================================================
## Each relationship is defined once with XSD cardinality.
## Profile restrictions are expressed separately below.
## -----------------------------------------------------------------

## --- ResourceFrame relationships ---

netex:Operator netex:hasRef [
    netex:property "AuthorityRef" ;
    netex:target netex:Authority ;
    netex:xsdCardinality "0..1"
] .

netex:Vehicle netex:hasRef [
    netex:property "OperatorRef" ;
    netex:target netex:Operator ;
    netex:xsdCardinality "0..1"
] , [
    netex:property "VehicleTypeRef" ;
    netex:target netex:VehicleType ;
    netex:xsdCardinality "0..1"
] .

netex:ResponsibilitySet netex:hasRef [
    netex:property "ResponsibleOrganisationRef" ;
    netex:target netex:Authority ;
    netex:xsdCardinality "0..1" ;
    netex:path "roles/ResponsibilityRoleAssignment/ResponsibleOrganisationRef"
] , [
    netex:property "ContractRef" ;
    netex:target netex:Contract ;
    netex:xsdCardinality "0..1" ;
    netex:path "roles/ResponsibilityRoleAssignment/AssociatedContract/ContractRef"
] .

netex:Contract netex:hasRef [
    netex:property "OrganisationRef (contractees)" ;
    netex:target netex:Authority ;
    netex:xsdCardinality "0..n" ;
    netex:path "contractees/OrganisationRef"
] , [
    netex:property "OrganisationRef (contractors)" ;
    netex:target netex:Operator ;
    netex:xsdCardinality "0..n" ;
    netex:path "contractors/OrganisationRef"
] .

## --- SiteFrame relationships ---

netex:StopPlace netex:hasRef [
    netex:property "TopographicPlaceRef" ;
    netex:target netex:TopographicPlace ;
    netex:xsdCardinality "0..1"
] , [
    netex:property "ParentSiteRef" ;
    netex:target netex:StopPlace ;
    netex:xsdCardinality "0..1" ;
    rdfs:comment "Multimodal parent stop — ERP only"
] , [
    netex:property "TariffZoneRef" ;
    netex:target netex:TariffZone ;
    netex:xsdCardinality "0..n"
] .

netex:StopPlace netex:hasComposition [
    netex:property "quays" ;
    netex:target netex:Quay ;
    netex:xsdCardinality "0..n"
] .

netex:TopographicPlace netex:hasRef [
    netex:property "ParentTopographicPlaceRef" ;
    netex:target netex:TopographicPlace ;
    netex:xsdCardinality "0..1"
] .

netex:Parking netex:hasRef [
    netex:property "ParentSiteRef" ;
    netex:target netex:StopPlace ;
    netex:xsdCardinality "0..1"
] .

netex:FareZone netex:hasRef [
    netex:property "ScheduledStopPointRef" ;
    netex:target netex:ScheduledStopPoint ;
    netex:xsdCardinality "0..n" ;
    netex:path "members/ScheduledStopPointRef"
] .

## --- ServiceCalendarFrame relationships ---

netex:DayTypeAssignment netex:hasRef [
    netex:property "DayTypeRef" ;
    netex:target netex:DayType ;
    netex:xsdCardinality "0..1"
] , [
    netex:property "OperatingPeriodRef" ;
    netex:target netex:OperatingPeriod ;
    netex:xsdCardinality "0..1" ;
    rdfs:comment "Mutually exclusive with Date"
] .

## --- ServiceFrame relationships ---

netex:Line netex:hasRef [
    netex:property "OperatorRef" ;
    netex:target netex:Operator ;
    netex:xsdCardinality "1..1"
] , [
    netex:property "RepresentedByGroupRef" ;
    netex:target netex:GroupOfLines ;
    netex:xsdCardinality "0..1" ;
    rdfs:comment "Can also target Network"
] .

netex:GroupOfLines netex:hasRef [
    netex:property "LineRef" ;
    netex:target netex:Line ;
    netex:xsdCardinality "1..n" ;
    netex:path "members/LineRef"
] .

netex:Route netex:hasRef [
    netex:property "LineRef" ;
    netex:target netex:Line ;
    netex:xsdCardinality "1..1"
] , [
    netex:property "InverseRouteRef" ;
    netex:target netex:Route ;
    netex:xsdCardinality "0..1" ;
    rdfs:comment "Bidirectional inverse route"
] , [
    netex:property "ScheduledStopPointRef" ;
    netex:target netex:ScheduledStopPoint ;
    netex:xsdCardinality "1..1" ;
    netex:path "pointsInSequence/PointOnRoute/ScheduledStopPointRef"
] .

netex:JourneyPattern netex:hasRef [
    netex:property "RouteRef" ;
    netex:target netex:Route ;
    netex:xsdCardinality "0..1"
] .

netex:JourneyPattern netex:hasComposition [
    netex:property "pointsInSequence" ;
    netex:target netex:StopPointInJourneyPattern ;
    netex:xsdCardinality "1..n"
] .

netex:StopPointInJourneyPattern netex:hasRef [
    netex:property "ScheduledStopPointRef" ;
    netex:target netex:ScheduledStopPoint ;
    netex:xsdCardinality "1..1"
] , [
    netex:property "DestinationDisplayRef" ;
    netex:target netex:DestinationDisplay ;
    netex:xsdCardinality "0..1"
] , [
    netex:property "NoticeRef" ;
    netex:target netex:Notice ;
    netex:xsdCardinality "0..1" ;
    netex:path "noticeAssignments/NoticeAssignment/NoticeRef"
] .

netex:PassengerStopAssignment netex:hasRef [
    netex:property "ScheduledStopPointRef" ;
    netex:target netex:ScheduledStopPoint ;
    netex:xsdCardinality "1..1"
] , [
    netex:property "StopPlaceRef" ;
    netex:target netex:StopPlace ;
    netex:xsdCardinality "0..1"
] , [
    netex:property "QuayRef" ;
    netex:target netex:Quay ;
    netex:xsdCardinality "1..1"
] .

## --- TimetableFrame relationships ---

netex:ServiceJourney netex:hasRef [
    netex:property "JourneyPatternRef" ;
    netex:target netex:JourneyPattern ;
    netex:xsdCardinality "1..1"
] , [
    netex:property "VehicleTypeRef" ;
    netex:target netex:VehicleType ;
    netex:xsdCardinality "0..1" ;
    rdfs:comment "Passenger-facing hint (expect low-floor bus), NOT operational assignment. Use BlockRef for actual vehicle assignment."
] , [
    netex:property "LineRef" ;
    netex:target netex:Line ;
    netex:xsdCardinality "0..1"
] , [
    netex:property "OperatorRef" ;
    netex:target netex:Operator ;
    netex:xsdCardinality "0..1"
] , [
    netex:property "DayTypeRef" ;
    netex:target netex:DayType ;
    netex:xsdCardinality "0..n" ;
    netex:path "dayTypes/DayTypeRef"
] , [
    netex:property "BlockRef" ;
    netex:target netex:TrainBlock ;
    netex:xsdCardinality "0..1"
] .

netex:ServiceJourney netex:hasComposition [
    netex:property "passingTimes" ;
    netex:target netex:TimetabledPassingTime ;
    netex:xsdCardinality "1..n"
] .

netex:DatedServiceJourney netex:hasRef [
    netex:property "ServiceJourneyRef" ;
    netex:target netex:ServiceJourney ;
    netex:xsdCardinality "1..1"
] , [
    netex:property "OperatingDayRef" ;
    netex:target netex:OperatingDay ;
    netex:xsdCardinality "1..1"
] , [
    netex:property "BlockRef" ;
    netex:target netex:TrainBlock ;
    netex:xsdCardinality "0..1"
] , [
    netex:property "DatedVehicleJourneyRef" ;
    netex:target netex:DatedServiceJourney ;
    netex:xsdCardinality "0..n" ;
    netex:path "replacedJourneys/DatedVehicleJourneyRef" ;
    rdfs:comment "Replaced/reinforced journeys — NP only"
] .

netex:Interchange netex:hasRef [
    netex:property "FromJourneyRef" ;
    netex:target netex:ServiceJourney ;
    netex:xsdCardinality "1..1"
] , [
    netex:property "ToJourneyRef" ;
    netex:target netex:ServiceJourney ;
    netex:xsdCardinality "1..1"
] , [
    netex:property "FromPointRef" ;
    netex:target netex:ScheduledStopPoint ;
    netex:xsdCardinality "0..1"
] , [
    netex:property "ToPointRef" ;
    netex:target netex:ScheduledStopPoint ;
    netex:xsdCardinality "0..1"
] .

## --- VehicleScheduleFrame relationships ---

netex:TrainBlock netex:hasRef [
    netex:property "OperatorRef" ;
    netex:target netex:Operator ;
    netex:xsdCardinality "0..1"
] .

netex:TrainBlock netex:hasComposition [
    netex:property "journeys" ;
    netex:target netex:ServiceJourney ;
    netex:xsdCardinality "0..n" ;
    netex:path "journeys/VehicleJourneyRef" ;
    rdfs:comment "Bidirectional: Block lists its journeys, journeys reference Block via BlockRef"
] .

## =================================================================
## PROFILE RESTRICTIONS
## =================================================================
## Elements that differ between ERP and NP.
## "excluded" = element not used in this profile.
## "required" = stricter than XSD (e.g. 0..1 → 1..1).
## Only divergences from XSD are listed.
## -----------------------------------------------------------------

## --- ERP-only relationships (excluded from NP) ---

profile:ERP netex:allows [
    netex:class netex:StopPlace ;
    netex:property "ParentSiteRef" ;
    netex:cardinality "0..1" ;
    rdfs:comment "Multimodal parent composition"
] , [
    netex:class netex:StopPlace ;
    netex:property "TariffZoneRef" ;
    netex:cardinality "0..n"
] , [
    netex:class netex:ServiceJourney ;
    netex:property "FlexibleLineRef" ;
    netex:cardinality "0..1"
] , [
    netex:class netex:ServiceJourney ;
    netex:property "BlockRef" ;
    netex:cardinality "0..1"
] .

profile:NP netex:excludes [
    netex:class netex:StopPlace ;
    netex:property "ParentSiteRef"
] , [
    netex:class netex:StopPlace ;
    netex:property "TariffZoneRef"
] , [
    netex:class netex:ServiceJourney ;
    netex:property "FlexibleLineRef"
] , [
    netex:class netex:ServiceJourney ;
    netex:property "BlockRef"
] .

## --- NP-only relationships (excluded from ERP) ---

profile:NP netex:allows [
    netex:class netex:StopPlace ;
    netex:property "TopographicPlaceRef" ;
    netex:cardinality "0..1"
] , [
    netex:class netex:StopPlace ;
    netex:property "ValidBetween" ;
    netex:cardinality "0..1"
] , [
    netex:class netex:StopPlace ;
    netex:property "AccessibilityAssessment" ;
    netex:cardinality "0..1"
] , [
    netex:class netex:Quay ;
    netex:property "AccessibilityAssessment" ;
    netex:cardinality "0..1"
] , [
    netex:class netex:Quay ;
    netex:property "boardingPositions" ;
    netex:cardinality "0..1"
] , [
    netex:class netex:Line ;
    netex:property "RepresentedByGroupRef" ;
    netex:cardinality "0..1"
] , [
    netex:class netex:Line ;
    netex:property "TransportSubmode" ;
    netex:cardinality "0..1"
] , [
    netex:class netex:Line ;
    netex:property "PublicCode" ;
    netex:cardinality "0..1"
] , [
    netex:class netex:Line ;
    netex:property "PrivateCode" ;
    netex:cardinality "0..1"
] , [
    netex:class netex:DatedServiceJourney ;
    netex:property "DatedVehicleJourneyRef" ;
    netex:cardinality "0..n" ;
    rdfs:comment "Deviation/replacement tracking"
] , [
    netex:class netex:Interchange ;
    netex:property "FromPointRef" ;
    netex:cardinality "0..1"
] , [
    netex:class netex:Interchange ;
    netex:property "ToPointRef" ;
    netex:cardinality "0..1"
] .

profile:ERP netex:excludes [
    netex:class netex:StopPlace ;
    netex:property "TopographicPlaceRef"
] , [
    netex:class netex:StopPlace ;
    netex:property "ValidBetween"
] , [
    netex:class netex:StopPlace ;
    netex:property "AccessibilityAssessment"
] , [
    netex:class netex:Quay ;
    netex:property "AccessibilityAssessment"
] , [
    netex:class netex:Quay ;
    netex:property "boardingPositions"
] , [
    netex:class netex:Line ;
    netex:property "RepresentedByGroupRef"
] , [
    netex:class netex:Line ;
    netex:property "TransportSubmode"
] , [
    netex:class netex:Line ;
    netex:property "PublicCode"
] , [
    netex:class netex:Line ;
    netex:property "PrivateCode"
] , [
    netex:class netex:DatedServiceJourney ;
    netex:property "DatedVehicleJourneyRef"
] , [
    netex:class netex:Interchange ;
    netex:property "FromPointRef"
] , [
    netex:class netex:Interchange ;
    netex:property "ToPointRef"
] .

## --- Cardinality tightening (XSD is looser than profile requires) ---

profile:NP netex:requires [
    netex:class netex:JourneyPattern ;
    netex:property "RouteRef" ;
    netex:cardinality "1..1" ;
    rdfs:comment "XSD allows 0..1, NP mandates"
] , [
    netex:class netex:Vehicle ;
    netex:property "VehicleTypeRef" ;
    netex:cardinality "1..1" ;
    rdfs:comment "XSD allows 0..1, NP mandates"
] , [
    netex:class netex:Authority ;
    netex:property "Name" ;
    netex:cardinality "1..1"
] , [
    netex:class netex:Operator ;
    netex:property "Name" ;
    netex:cardinality "1..1"
] , [
    netex:class netex:VehicleType ;
    netex:property "Name" ;
    netex:cardinality "1..1"
] , [
    netex:class netex:FareZone ;
    netex:property "Name" ;
    netex:cardinality "1..1"
] .

## =================================================================
## DOMAIN CHAINS (navigational shortcuts)
## =================================================================
## Common traversal paths for planning a NeTEx delivery.
## -----------------------------------------------------------------

netex:TimetableChain rdfs:comment """
    Line → Route → JourneyPattern → ServiceJourney → DatedServiceJourney
    The core modelling chain: from abstract line identity
    through physical route, stop sequence, timed trip template,
    to a concrete instance on a specific date.
""" ;
    netex:step1 netex:Line ;
    netex:step2 netex:Route ;
    netex:step3 netex:JourneyPattern ;
    netex:step4 netex:ServiceJourney ;
    netex:step5 netex:DatedServiceJourney .

netex:StopChain rdfs:comment """
    ScheduledStopPoint → PassengerStopAssignment → StopPlace → Quay
    The logical-to-physical stop bridge.
""" ;
    netex:step1 netex:ScheduledStopPoint ;
    netex:step2 netex:PassengerStopAssignment ;
    netex:step3 netex:StopPlace ;
    netex:step4 netex:Quay .

netex:CalendarChain rdfs:comment """
    DayType → DayTypeAssignment → OperatingPeriod / Date
    How services are bound to dates.
""" ;
    netex:step1 netex:DayType ;
    netex:step2 netex:DayTypeAssignment ;
    netex:step3 netex:OperatingPeriod .

netex:OrganisationChain rdfs:comment """
    Authority → Contract → Operator → ResponsibilitySet
    Organisational governance and responsibility.
""" ;
    netex:step1 netex:Authority ;
    netex:step2 netex:Contract ;
    netex:step3 netex:Operator ;
    netex:step4 netex:ResponsibilitySet .

