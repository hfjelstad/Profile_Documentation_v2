name: External NeTEx validator

on:
  workflow_dispatch:
    inputs:
      xmlContent:
        description: "Raw XML to validate"
        required: true
        type: string

jobs:
  NeTEx_External:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with: { fetch-depth: 0 }

      - name: Write XML to file
        run: |
          echo "${{ github.event.inputs.xmlContent }}" > input.xml

      - name: Install validator
        run: sudo apt-get update && sudo apt-get install -y libxml2-utils

      - name: Validate with NeTEx XSD
        id: validate
        run: |
          xmllint --noout --schema "XSD 2.0/xsd/NeTEx_publication.xsd" input.xml 2> errors.txt || true
          cat errors.txt

      - name: Set output
        id: result
        run: |
          {
            echo "errors<<EOF"
            cat errors.txt
            echo "EOF"
          } >> $GITHUB_OUTPUT

    outputs:
      errors: ${{ steps.result.outputs.errors }}
