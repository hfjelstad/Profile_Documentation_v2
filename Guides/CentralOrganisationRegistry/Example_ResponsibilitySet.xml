<?xml version="1.0" encoding="UTF-8"?>
<!--
  Example: ResponsibilitySet as Role-Assignment Model
  
  Demonstrates using ResponsibilitySet to assign organisational roles (planning,
  operation, etc.) to Lines and ServiceJourneys, instead of (or alongside)
  direct AuthorityRef/OperatorRef elements.
  
  All organisations are modelled as GeneralOrganisation — role-neutral, with the
  stakeholder role defined in the ResponsibilityRoleAssignment.
  
  Validates against: NeTEx_publication.xsd (full key/keyref constraints)
-->
<PublicationDelivery xmlns="http://www.netex.org.uk/netex"
                     xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                     xsi:schemaLocation="http://www.netex.org.uk/netex NeTEx_publication.xsd"
                     version="1.0">
  <PublicationTimestamp>2026-04-17T12:00:00</PublicationTimestamp>
  <ParticipantRef>ENT</ParticipantRef>

  <dataObjects>
    <CompositeFrame id="ENT:CompositeFrame:ResponsibilitySetExample" version="1">
      <validityConditions>
        <AvailabilityCondition id="ENT:AvailabilityCondition:1" version="1">
          <FromDate>2026-01-01T00:00:00</FromDate>
          <ToDate>2026-12-31T23:59:59</ToDate>
        </AvailabilityCondition>
      </validityConditions>
      <codespaces>
        <Codespace id="reg">
          <Xmlns>REG</Xmlns>
          <XmlnsUrl>https://registry.example.org/netex</XmlnsUrl>
        </Codespace>
        <Codespace id="con">
          <Xmlns>CON</Xmlns>
          <XmlnsUrl>https://contracts.example.org/netex</XmlnsUrl>
        </Codespace>
        <Codespace id="ent">
          <Xmlns>ENT</Xmlns>
          <XmlnsUrl>https://entransit.example.org/netex</XmlnsUrl>
        </Codespace>
      </codespaces>

      <frames>

        <!-- ============================================================ -->
        <!-- ResourceFrame: Organisations and ResponsibilitySets          -->
        <!-- ============================================================ -->
        <ResourceFrame id="ENT:ResourceFrame:Registry" version="1">

          <!-- ResponsibilitySets: role assignments owned by ENT (delivery concern) -->
          <responsibilitySets>

            <!-- Pattern 1: Same org is both planner and operator -->
            <ResponsibilitySet id="ENT:ResponsibilitySet:SelfOperated" version="1">
              <Name>Self-operated (planning + operation)</Name>
              <roles>
                <ResponsibilityRoleAssignment id="ENT:ResponsibilityRoleAssignment:SO-Auth" version="1">
                  <StakeholderRoleType>planning</StakeholderRoleType>
                  <ResponsibleOrganisationRef ref="REG:GeneralOrganisation:KommuneTransport"/>
                  <AssociatedContract>
                    <ContractRef ref="CON:Contract:KT-SelfOp-2026"/>
                  </AssociatedContract>
                </ResponsibilityRoleAssignment>
                <ResponsibilityRoleAssignment id="ENT:ResponsibilityRoleAssignment:SO-Oper" version="1">
                  <StakeholderRoleType>operation</StakeholderRoleType>
                  <ResponsibleOrganisationRef ref="REG:GeneralOrganisation:KommuneTransport"/>
                  <AssociatedContract>
                    <ContractRef ref="CON:Contract:KT-SelfOp-2026"/>
                  </AssociatedContract>
                </ResponsibilityRoleAssignment>
              </roles>
            </ResponsibilitySet>

            <!-- Pattern 2: Split authority (planning) and operator -->
            <ResponsibilitySet id="ENT:ResponsibilitySet:FylkePrivat" version="1">
              <Name>Fylke-commissioned, privately operated</Name>
              <roles>
                <ResponsibilityRoleAssignment id="ENT:ResponsibilityRoleAssignment:FP-Auth" version="1">
                  <StakeholderRoleType>planning</StakeholderRoleType>
                  <ResponsibleOrganisationRef ref="REG:GeneralOrganisation:Fylkeskommune"/>
                  <AssociatedContract>
                    <ContractRef ref="CON:Contract:FK-PB-2026"/>
                  </AssociatedContract>
                </ResponsibilityRoleAssignment>
                <ResponsibilityRoleAssignment id="ENT:ResponsibilityRoleAssignment:FP-Oper" version="1">
                  <StakeholderRoleType>operation</StakeholderRoleType>
                  <ResponsibleOrganisationRef ref="REG:GeneralOrganisation:PrivatBuss"/>
                  <AssociatedContract>
                    <ContractRef ref="CON:Contract:FK-PB-2026"/>
                  </AssociatedContract>
                </ResponsibilityRoleAssignment>
              </roles>
            </ResponsibilitySet>

            <!-- Pattern 3: Substitute operator for specific journeys -->
            <ResponsibilitySet id="ENT:ResponsibilitySet:SubstitutOper" version="1">
              <Name>Substitute operator</Name>
              <roles>
                <ResponsibilityRoleAssignment id="ENT:ResponsibilityRoleAssignment:Sub-Oper" version="1">
                  <StakeholderRoleType>operation</StakeholderRoleType>
                  <ResponsibleOrganisationRef ref="REG:GeneralOrganisation:SubstituBuss"/>
                  <AssociatedContract>
                    <ContractRef ref="CON:Contract:FK-SB-2026"/>
                  </AssociatedContract>
                </ResponsibilityRoleAssignment>
              </roles>
            </ResponsibilitySet>

          </responsibilitySets>

          <!-- Contracts from external contract registry (CON codespace) -->
          <contracts>
            <Contract id="CON:Contract:KT-SelfOp-2026" version="1">
              <Name>KommuneTransport self-operation agreement 2026</Name>
              <ContractType>formal</ContractType>
              <LegalStatus>binding</LegalStatus>
              <contractees>
                <OrganisationRef ref="REG:GeneralOrganisation:KommuneTransport"/>
              </contractees>
              <contractors>
                <OrganisationRef ref="REG:GeneralOrganisation:KommuneTransport"/>
              </contractors>
            </Contract>
            <Contract id="CON:Contract:FK-PB-2026" version="1">
              <Name>Fylkeskommune - PrivatBuss operating contract 2026</Name>
              <ContractType>formal</ContractType>
              <LegalStatus>binding</LegalStatus>
              <contractees>
                <OrganisationRef ref="REG:GeneralOrganisation:Fylkeskommune"/>
              </contractees>
              <contractors>
                <OrganisationRef ref="REG:GeneralOrganisation:PrivatBuss"/>
              </contractors>
            </Contract>
            <Contract id="CON:Contract:FK-SB-2026" version="1">
              <Name>Fylkeskommune - SubstituBuss substitute contract 2026</Name>
              <ContractType>formal</ContractType>
              <LegalStatus>binding</LegalStatus>
              <contractees>
                <OrganisationRef ref="REG:GeneralOrganisation:Fylkeskommune"/>
              </contractees>
              <contractors>
                <OrganisationRef ref="REG:GeneralOrganisation:SubstituBuss"/>
              </contractors>
            </Contract>
          </contracts>

          <!-- Organisations as GeneralOrganisation (role-neutral) -->
          <organisations>
            <GeneralOrganisation id="REG:GeneralOrganisation:KommuneTransport" version="1">
              <Name>KommuneTransport AS</Name>
              <ContactDetails>
                <Url>https://www.kommunetransport.example.no</Url>
              </ContactDetails>
            </GeneralOrganisation>
            <GeneralOrganisation id="REG:GeneralOrganisation:Fylkeskommune" version="1">
              <Name>Fylkeskommune Mobilitet</Name>
              <ContactDetails>
                <Url>https://www.fylkeskommune.example.no</Url>
              </ContactDetails>
            </GeneralOrganisation>
            <GeneralOrganisation id="REG:GeneralOrganisation:PrivatBuss" version="1">
              <Name>PrivatBuss Norge AS</Name>
            </GeneralOrganisation>
            <GeneralOrganisation id="REG:GeneralOrganisation:SubstituBuss" version="1">
              <Name>SubstituBuss AS</Name>
            </GeneralOrganisation>
          </organisations>
        </ResourceFrame>

        <!-- ============================================================ -->
        <!-- ServiceFrame: Lines using responsibilitySetRef               -->
        <!-- ============================================================ -->
        <ServiceFrame id="ENT:ServiceFrame:Lines" version="1">

          <Network id="ENT:Network:1" version="1">
            <Name>Eksempelnett</Name>
          </Network>

          <routePoints>
            <RoutePoint id="ENT:RoutePoint:A" version="1">
              <projections>
                <PointProjection id="ENT:PointProjection:A" version="1">
                  <ProjectedPointRef ref="ENT:ScheduledStopPoint:A" version="1"/>
                </PointProjection>
              </projections>
            </RoutePoint>
            <RoutePoint id="ENT:RoutePoint:B" version="1">
              <projections>
                <PointProjection id="ENT:PointProjection:B" version="1">
                  <ProjectedPointRef ref="ENT:ScheduledStopPoint:B" version="1"/>
                </PointProjection>
              </projections>
            </RoutePoint>
          </routePoints>

          <routes>
            <Route id="ENT:Route:1" version="1">
              <Name>Route 1</Name>
              <LineRef ref="ENT:Line:1" version="1"/>
              <DirectionType>outbound</DirectionType>
              <pointsInSequence>
                <PointOnRoute id="ENT:PointOnRoute:1-A" version="1" order="1">
                  <RoutePointRef ref="ENT:RoutePoint:A" version="1"/>
                </PointOnRoute>
                <PointOnRoute id="ENT:PointOnRoute:1-B" version="1" order="2">
                  <RoutePointRef ref="ENT:RoutePoint:B" version="1"/>
                </PointOnRoute>
              </pointsInSequence>
            </Route>
            <Route id="ENT:Route:2" version="1">
              <Name>Route 2</Name>
              <LineRef ref="ENT:Line:2" version="1"/>
              <DirectionType>outbound</DirectionType>
              <pointsInSequence>
                <PointOnRoute id="ENT:PointOnRoute:2-A" version="1" order="1">
                  <RoutePointRef ref="ENT:RoutePoint:A" version="1"/>
                </PointOnRoute>
                <PointOnRoute id="ENT:PointOnRoute:2-B" version="1" order="2">
                  <RoutePointRef ref="ENT:RoutePoint:B" version="1"/>
                </PointOnRoute>
              </pointsInSequence>
            </Route>
          </routes>

          <lines>
            <!-- Line 1: Self-operated (KommuneTransport plans AND operates) -->
            <Line id="ENT:Line:1" version="1"
                  responsibilitySetRef="ENT:ResponsibilitySet:SelfOperated">
              <Name>Stadsbuss 1</Name>
              <TransportMode>bus</TransportMode>
            </Line>

            <!-- Line 2: Split roles (Fylkeskommune plans, PrivatBuss operates) -->
            <Line id="ENT:Line:2" version="1"
                  responsibilitySetRef="ENT:ResponsibilitySet:FylkePrivat">
              <Name>Regionbuss 2</Name>
              <TransportMode>bus</TransportMode>
            </Line>
          </lines>

          <scheduledStopPoints>
            <ScheduledStopPoint id="ENT:ScheduledStopPoint:A" version="1">
              <Name>Sentrum</Name>
            </ScheduledStopPoint>
            <ScheduledStopPoint id="ENT:ScheduledStopPoint:B" version="1">
              <Name>Utkanten</Name>
            </ScheduledStopPoint>
          </scheduledStopPoints>

          <journeyPatterns>
            <JourneyPattern id="ENT:JourneyPattern:1A" version="1">
              <RouteRef ref="ENT:Route:1" version="1"/>
              <pointsInSequence>
                <StopPointInJourneyPattern id="ENT:StopPointInJourneyPattern:1A-1" version="1" order="1">
                  <ScheduledStopPointRef ref="ENT:ScheduledStopPoint:A" version="1"/>
                </StopPointInJourneyPattern>
                <StopPointInJourneyPattern id="ENT:StopPointInJourneyPattern:1A-2" version="1" order="2">
                  <ScheduledStopPointRef ref="ENT:ScheduledStopPoint:B" version="1"/>
                </StopPointInJourneyPattern>
              </pointsInSequence>
            </JourneyPattern>
          </journeyPatterns>

        </ServiceFrame>

        <!-- ============================================================ -->
        <!-- TimetableFrame: ServiceJourney with responsibility override  -->
        <!-- ============================================================ -->
        <TimetableFrame id="ENT:TimetableFrame:T1" version="1">
          <vehicleJourneys>

            <!-- Normal journey on Line 1 — inherits Line's responsibilitySet -->
            <ServiceJourney id="ENT:ServiceJourney:1001" version="1">
              <dayTypes>
                <DayTypeRef ref="ENT:DayType:Weekdays" version="1"/>
              </dayTypes>
              <JourneyPatternRef ref="ENT:JourneyPattern:1A" version="1"/>
              <passingTimes>
                <TimetabledPassingTime id="ENT:TimetabledPassingTime:1001-A" version="1">
                  <StopPointInJourneyPatternRef ref="ENT:StopPointInJourneyPattern:1A-1" version="1"/>
                  <DepartureTime>07:00:00</DepartureTime>
                </TimetabledPassingTime>
                <TimetabledPassingTime id="ENT:TimetabledPassingTime:1001-B" version="1">
                  <StopPointInJourneyPatternRef ref="ENT:StopPointInJourneyPattern:1A-2" version="1"/>
                  <ArrivalTime>07:25:00</ArrivalTime>
                </TimetabledPassingTime>
              </passingTimes>
            </ServiceJourney>

            <!-- Substitute journey — overrides operator via separate ResponsibilitySet -->
            <ServiceJourney id="ENT:ServiceJourney:1002" version="1"
                            responsibilitySetRef="ENT:ResponsibilitySet:SubstitutOper">
              <dayTypes>
                <DayTypeRef ref="ENT:DayType:Weekdays" version="1"/>
              </dayTypes>
              <JourneyPatternRef ref="ENT:JourneyPattern:1A" version="1"/>
              <passingTimes>
                <TimetabledPassingTime id="ENT:TimetabledPassingTime:1002-A" version="1">
                  <StopPointInJourneyPatternRef ref="ENT:StopPointInJourneyPattern:1A-1" version="1"/>
                  <DepartureTime>08:00:00</DepartureTime>
                </TimetabledPassingTime>
                <TimetabledPassingTime id="ENT:TimetabledPassingTime:1002-B" version="1">
                  <StopPointInJourneyPatternRef ref="ENT:StopPointInJourneyPattern:1A-2" version="1"/>
                  <ArrivalTime>08:25:00</ArrivalTime>
                </TimetabledPassingTime>
              </passingTimes>
            </ServiceJourney>

          </vehicleJourneys>
        </TimetableFrame>

        <!-- ============================================================ -->
        <!-- ServiceCalendarFrame: DayType referenced by journeys         -->
        <!-- ============================================================ -->
        <ServiceCalendarFrame id="ENT:ServiceCalendarFrame:SC1" version="1">
          <dayTypes>
            <DayType id="ENT:DayType:Weekdays" version="1">
              <Name>Weekdays</Name>
              <properties>
                <PropertyOfDay>
                  <DaysOfWeek>Monday Tuesday Wednesday Thursday Friday</DaysOfWeek>
                </PropertyOfDay>
              </properties>
            </DayType>
          </dayTypes>
        </ServiceCalendarFrame>

      </frames>
    </CompositeFrame>
  </dataObjects>
</PublicationDelivery>
