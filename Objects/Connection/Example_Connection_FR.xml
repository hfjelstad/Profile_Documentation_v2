<?xml version="1.0" encoding="UTF-8"?>
<!-- Example: Connection between Gare de Lyon (bus) and Gare de Lyon (rail) -->
<Connection id="FR:Connection:GareDeLyon_BusToRail" version="1">
  <Name>Gare de Lyon bus stop to Gare de Lyon railway platforms</Name>
  <Description>Walking transfer from the bus stop to the railway platforms at Gare de Lyon.</Description>
  <Distance>250</Distance>
  <BothWays>true</BothWays>
  <TransferDuration>
    <DefaultDuration>PT4M</DefaultDuration>
    <FrequentTravellerDuration>PT3M</FrequentTravellerDuration>
    <OccasionalTravellerDuration>PT6M</OccasionalTravellerDuration>
    <MobilityRestrictedTravellerDuration>PT8M</MobilityRestrictedTravellerDuration>
  </TransferDuration>
  <From>
    <ScheduledStopPointRef ref="FR:ScheduledStopPoint:GareDeLyon_Bus"/>
    <TransportMode>bus</TransportMode>
  </From>
  <To>
    <ScheduledStopPointRef ref="FR:ScheduledStopPoint:GareDeLyon_Rail"/>
    <TransportMode>rail</TransportMode>
  </To>
</Connection>
