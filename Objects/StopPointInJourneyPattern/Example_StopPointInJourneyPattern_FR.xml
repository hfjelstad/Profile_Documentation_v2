<?xml version="1.0" encoding="UTF-8"?>
<!-- Example: Rich StopPointInJourneyPattern usage within a JourneyPattern -->
<!-- Showing destination display changes, request stop, and booking arrangements -->
<JourneyPattern id="FR:JourneyPattern:FlexLigne7" version="1">
  <Name>Ligne 7 Flex aller</Name>
  <RouteRef ref="FR:Route:7_Aller"/>
  <pointsInSequence>
    <!-- First stop: boarding only, initial destination display -->
    <StopPointInJourneyPattern id="FR:StopPointInJourneyPattern:L7-1" version="1" order="1">
      <ScheduledStopPointRef ref="FR:ScheduledStopPoint:GareRoutiere"/>
      <ForAlighting>false</ForAlighting>
      <ForBoarding>true</ForBoarding>
      <DestinationDisplayRef ref="FR:DestinationDisplay:SaintMalo"/>
    </StopPointInJourneyPattern>

    <!-- Mid stop: regular stop with notice -->
    <StopPointInJourneyPattern id="FR:StopPointInJourneyPattern:L7-2" version="1" order="2">
      <ScheduledStopPointRef ref="FR:ScheduledStopPoint:PlaceDeLaRepublique"/>
      <ForAlighting>true</ForAlighting>
      <ForBoarding>true</ForBoarding>
      <noticeAssignments>
        <NoticeAssignment id="FR:NoticeAssignment:L7-2-JoursScolaires" version="1" order="1">
          <NoticeRef ref="FR:Notice:JoursScolairesUniquement"/>
        </NoticeAssignment>
      </noticeAssignments>
    </StopPointInJourneyPattern>

    <!-- Flexible request stop with booking (demand-responsive) -->
    <StopPointInJourneyPattern id="FR:StopPointInJourneyPattern:L7-3" version="1" order="3">
      <ScheduledStopPointRef ref="FR:ScheduledStopPoint:CarrefourDuVillage"/>
      <ForAlighting>true</ForAlighting>
      <ForBoarding>true</ForBoarding>
      <RequestStop>true</RequestStop>
      <RequestMethod>phoneCall</RequestMethod>
      <BookingArrangements>
        <BookingAccess>public</BookingAccess>
        <BookWhen>advanceOnly</BookWhen>
        <LatestBookingTime>16:00:00</LatestBookingTime>
        <MinimumBookingPeriod>PT2H</MinimumBookingPeriod>
        <BookingNote>Appelez le transporteur au +33 2 99 12 34 56 pour réserver cet arrêt.</BookingNote>
        <BookingMethods>
          <BookingMethod>callOffice</BookingMethod>
        </BookingMethods>
      </BookingArrangements>
    </StopPointInJourneyPattern>

    <!-- Destination display change at this stop -->
    <StopPointInJourneyPattern id="FR:StopPointInJourneyPattern:L7-4" version="1" order="4">
      <ScheduledStopPointRef ref="FR:ScheduledStopPoint:PortDePlaisance"/>
      <ForAlighting>true</ForAlighting>
      <ForBoarding>true</ForBoarding>
      <DestinationDisplayRef ref="FR:DestinationDisplay:SaintMalo_via_Port"/>
      <ChangeOfDestinationDisplay>true</ChangeOfDestinationDisplay>
    </StopPointInJourneyPattern>

    <!-- Last stop: alighting only -->
    <StopPointInJourneyPattern id="FR:StopPointInJourneyPattern:L7-5" version="1" order="5">
      <ScheduledStopPointRef ref="FR:ScheduledStopPoint:SaintMalo"/>
      <ForAlighting>true</ForAlighting>
      <ForBoarding>false</ForBoarding>
    </StopPointInJourneyPattern>
  </pointsInSequence>
</JourneyPattern>
